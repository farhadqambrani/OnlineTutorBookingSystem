@model IEnumerable<OnlineTutorBookingSystem.Models.TutorProfile>
@{
    ViewData["Title"] = "Tutors";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Find tutors</h2>
        <form class="d-flex" method="get">
            <input class="form-control me-2" name="q" placeholder="Search by subject, name or keyword" />
            <button class="btn btn-outline-primary">Search</button>
        </form>
    </div>

    <div class="mb-3 text-muted">@Model.Count() tutors available</div>

    <div class="row g-4">
        @foreach(var t in Model)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card card-tutor h-100">
                    <div class="d-flex align-items-center">
                        <img src="@(t.ProfilePictureUrl ?? "https://via.placeholder.com/120")" class="rounded-circle me-3 avatar-lg" width="72" height="72" />
                        <div class="flex-grow-1">
                            <h5 class="mb-1">@t.User?.FullName</h5>
                            <div class="text-muted small">@t.Headline</div>
                        </div>
                        <div class="text-end ms-3">
                            <div class="h5 mb-0">$@t.HourlyRate</div>
                            <div class="small text-muted">@t.Rating ★</div>
                        </div>
                    </div>

                    <p class="mt-3 text-muted">@t.Bio</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="small text-muted">@t.Languages • @t.Country</div>
                        <div>
                            <a class="btn btn-sm btn-outline-primary me-2" href="@Url.Action("Details", "Tutors", new { id = t.TutorProfileId })">Profile</a>
                            <a class="btn btn-sm btn-primary" href="#">Book</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
