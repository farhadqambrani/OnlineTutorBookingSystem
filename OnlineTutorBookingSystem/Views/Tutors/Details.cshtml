@model OnlineTutorBookingSystem.Models.TutorProfile
@{
    ViewData["Title"] = Model.Headline;
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-4">
            <img src="@(Model.ProfilePictureUrl ?? "https://via.placeholder.com/240")" class="img-fluid rounded" />
            <div class="mt-3">
                <div class="h3">$@Model.HourlyRate <small class="text-muted">/hr</small></div>
                <div class="mt-2"><span class="tag">@Model.Rating ★</span> <span class="ms-2 small text-muted">@Model.StudentsCount students • @Model.LessonsCount lessons</span></div>
                <a href="#" class="btn btn-primary btn-lg mt-3">Book a lesson</a>
            </div>
        </div>
        <div class="col-md-8">
            <h2>@Model.User?.FullName</h2>
            <h4 class="text-muted">@Model.Headline</h4>
            <p class="mt-3">@Model.Bio</p>
            <dl class="row">
                <dt class="col-sm-3">Languages</dt>
                <dd class="col-sm-9">@Model.Languages</dd>

                <dt class="col-sm-3">Location</dt>
                <dd class="col-sm-9">@Model.Country</dd>

                <dt class="col-sm-3">Experience</dt>
                <dd class="col-sm-9">@Model.Experience</dd>
            </dl>
        </div>
    </div>
</div>

