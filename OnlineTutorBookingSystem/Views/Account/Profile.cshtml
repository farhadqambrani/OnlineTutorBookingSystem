@model OnlineTutorBookingSystem.Models.User
@{
    ViewData["Title"] = "Profile";
}

<div class="container py-5">
    <div class="card p-4 mx-auto" style="max-width:720px;">
        <div class="d-flex align-items-center">
            <img src="https://via.placeholder.com/96" class="rounded-circle me-3" width="96" height="96" />
            <div>
                <h4>@Model.FullName</h4>
                <div class="text-muted">@Model.Email</div>
                <div class="mt-2"><span class="badge bg-primary">@Model.Role</span></div>
            </div>
        </div>

        <hr />

        <h5>Account details</h5>
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
        </dl>

        <a class="btn btn-outline-primary" href="/Student/Dashboard">Go to Dashboard</a>
    </div>
</div>
