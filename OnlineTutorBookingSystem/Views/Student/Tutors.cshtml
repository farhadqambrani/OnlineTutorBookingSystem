@model IEnumerable<OnlineTutorBookingSystem.Models.TutorProfile>

@{
    ViewData["Title"] = "Tutors";
}

<div class="container mt-4">
    <h2 class="mb-4">Available Tutors</h2>

    <div class="row">
        @foreach (var tutor in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow h-100">
                    <div class="card-body">
                        <h4>@tutor.User.FullName</h4>
                        <p><strong>Subject:</strong> @tutor.Subject.SubjectName</p>
                        <p><strong>Rate:</strong> Rs. @tutor.HourlyRate / hour</p>
                        <p><strong>Experience:</strong> @tutor.Experience</p>

                        <a href="/Student/TutorDetails/@tutor.TutorProfileId" class="btn btn-primary">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <a href="/Student/Dashboard" class="btn btn-secondary mt-3">Back</a>
</div>