@{
    ViewData["Title"] = "Home";
}

<section class="py-4">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Why choose LearnHub?</h2>
            <p class="text-muted">Fast bookings, verified tutors, and personalized learning plans.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card p-4 h-100 text-center">
                    <div class="mb-3 display-6">🎯</div>
                    <h5 class="mb-2">Focused Learning</h5>
                    <p class="text-muted">Tailored lessons that match your goals and pace.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 h-100 text-center">
                    <div class="mb-3 display-6">🗓️</div>
                    <h5 class="mb-2">Flexible Scheduling</h5>
                    <p class="text-muted">Book sessions that fit your busy life, cancel or reschedule easily.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 h-100 text-center">
                    <div class="mb-3 display-6">⭐</div>
                    <h5 class="mb-2">Verified Tutors</h5>
                    <p class="text-muted">Profiles with reviews, qualifications, and sample videos.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0">Top Tutors</h3>
            <a href="/Tutors" class="btn btn-outline-primary">View all tutors</a>
        </div>

        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card card-tutor p-3 h-100">
                    <div class="d-flex align-items-center">
                        <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=200&h=200&fit=crop" class="rounded-circle me-3 avatar-lg" alt="Tutor">
                        <div>
                            <h6 class="mb-0">Sarah Johnson</h6>
                            <small class="text-muted">Mathematics • $30/hr</small>
                        </div>
                    </div>
                    <p class="mt-3 mb-0 text-muted">Experienced high school math tutor — exam prep and concept mastery.</p>
                    <div class="mt-3 d-flex justify-content-between align-items-center">
                        <span class="tag">Verified</span>
                        <a href="/Tutors/Details/1" class="btn btn-sm btn-primary">Book</a>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-tutor p-3 h-100">
                    <div class="d-flex align-items-center">
                        <img src="https://images.unsplash.com/photo-1547425260-76bcadfb4f2c?w=200&h=200&fit=crop" class="rounded-circle me-3 avatar-lg" alt="Tutor">
                        <div>
                            <h6 class="mb-0">David Lee</h6>
                            <small class="text-muted">English • $25/hr</small>
                        </div>
                    </div>
                    <p class="mt-3 mb-0 text-muted">Conversation and writing improvement for adults and teens.</p>
                    <div class="mt-3 d-flex justify-content-between align-items-center">
                        <span class="tag">New</span>
                        <a href="/Tutors/Details/2" class="btn btn-sm btn-primary">Book</a>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-tutor p-3 h-100">
                    <div class="d-flex align-items-center">
                        <img src="https://images.unsplash.com/photo-1545996124-2e3b0f0f0f0f?w=200&h=200&fit=crop" class="rounded-circle me-3 avatar-lg" alt="Tutor">
                        <div>
                            <h6 class="mb-0">Aisha Khan</h6>
                            <small class="text-muted">Physics • $35/hr</small>
                        </div>
                    </div>
                    <p class="mt-3 mb-0 text-muted">University-level physics with hands-on problem solving.</p>
                    <div class="mt-3 d-flex justify-content-between align-items-center">
                        <span class="tag">Top Rated</span>
                        <a href="/Tutors/Details/3" class="btn btn-sm btn-primary">Book</a>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card card-tutor p-3 h-100">
                    <div class="d-flex align-items-center">
                        <img src="https://images.unsplash.com/photo-1544006659-f0b21884ce1d?w=200&h=200&fit=crop" class="rounded-circle me-3 avatar-lg" alt="Tutor">
                        <div>
                            <h6 class="mb-0">Michael Chen</h6>
                            <small class="text-muted">Programming • $40/hr</small>
                        </div>
                    </div>
                    <p class="mt-3 mb-0 text-muted">Backend and full-stack development with real project experience.</p>
                    <div class="mt-3 d-flex justify-content-between align-items-center">
                        <span class="tag">Popular</span>
                        <a href="/Tutors/Details/4" class="btn btn-sm btn-primary">Book</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

