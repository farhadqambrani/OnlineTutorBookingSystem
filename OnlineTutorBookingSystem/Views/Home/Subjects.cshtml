@model IEnumerable<OnlineTutorBookingSystem.Models.Subject>

@{
    ViewData["Title"] = "Subjects";
}

<div class="container py-5">
    <div class="hero mb-4 p-4 rounded shadow-sm" style="background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(186,158,147,0.14)); border-radius:12px;">
        <h1 class="display-5">Explore Subjects</h1>
        <p class="lead text-muted">Find expert tutors across popular subjects and start learning today.</p>
    </div>

    <div class="row g-4 mt-3">
        @foreach (var subject in Model)
        {
            <div class="col-12 col-sm-6 col-md-4">
                <div class="card h-100 rounded shadow-sm border-0" style="border-radius:12px; background: rgba(255,255,255,0.9);">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@subject.SubjectName</h5>
                        <p class="card-text text-muted">@GetSubjectDescription(subject.SubjectName)</p>
                        <div class="mt-auto">
                            <a href="/Student/Tutors" class="btn btn-primary">Find Tutors</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@functions{
    private string GetSubjectDescription(string name)
    {
        return name switch
        {
            "English" => "Improve reading, writing and communication skills with experienced tutors.",
            "Mathematics" => "Master core math concepts from arithmetic to advanced calculus.",
            "Computer Science" => "Learn programming, algorithms and problem solving.",
            "Physics" => "Understand the laws of nature with practical explanations and examples.",
            "Chemistry" => "Explore chemical principles and lab-based reasoning.",
            _ => "Expert tutors ready to help you succeed."
        };
    }
}
