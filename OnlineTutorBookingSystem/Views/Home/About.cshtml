@{
    ViewData["Title"] = "About";
}

<div class="container py-5">
    <section class="hero p-5 rounded shadow-sm mb-4" style="background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(186,158,147,0.12)); border-radius:12px;">
        <div class="row align-items-center">
            <div class="col-md-7">
                <h1 class="display-4">About LearnHub</h1>
                <p class="lead text-muted">Empowering learners and teachers worldwide — one lesson at a time.</p>
                <p>At LearnHub we believe education should be accessible, engaging, and tailored to each student's needs. Our platform connects motivated students with passionate tutors for live, personalized learning.</p>
                <a href="/Account/Register" class="btn btn-primary btn-lg mt-3">Start Learning</a>
            </div>
            <div class="col-md-5 text-center">
                <img src="https://images.unsplash.com/photo-1529070538774-1843cb3265df?w=800" class="img-fluid rounded shadow-sm" alt="LearnHub" />
            </div>
        </div>
    </section>

    <section class="features row g-4">
        <div class="col-md-4">
            <div class="card h-100 rounded shadow-sm" style="background: rgba(255,255,255,0.92); border-radius:12px;">
                <div class="card-body">
                    <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=800&q=80&auto=format&fit=crop" class="img-fluid rounded mb-3" alt="Personalized Learning" />
                    <h5 class="card-title">Personalized Learning</h5>
                    <p class="card-text text-muted">Get one-on-one support that focuses on your goals, pace, and preferred learning style.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 rounded shadow-sm" style="background: rgba(255,255,255,0.92); border-radius:12px;">
                <div class="card-body">
                    <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=800&q=80&auto=format&fit=crop" class="img-fluid rounded mb-3" alt="Qualified Tutors" />
                    <h5 class="card-title">Qualified Tutors</h5>
                    <p class="card-text text-muted">Our tutors are vetted and experienced, ready to guide you through challenges and milestones.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 rounded shadow-sm" style="background: rgba(255,255,255,0.92); border-radius:12px;">
                <div class="card-body">
                    <img src="https://images.unsplash.com/photo-1508780709619-79562169bc64?w=800&q=80&auto=format&fit=crop" class="img-fluid rounded mb-3" alt="Flexible Scheduling" />
                    <h5 class="card-title">Flexible Scheduling</h5>
                    <p class="card-text text-muted">Book lessons that fit your timetable and reschedule easily when life happens.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="mt-4 p-4 rounded shadow-sm" style="background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(186,158,147,0.06)); border-radius:12px;">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h3>Our Mission</h3>
                <p class="text-muted">We aim to close learning gaps by connecting students with high-quality tutors and by offering tools that make learning measurable, motivating, and meaningful.</p>
                <p>Whether you're a student seeking to improve grades or a tutor eager to share knowledge, LearnHub supports your journey with a friendly community and powerful scheduling tools.</p>
            </div>
            <div class="col-md-4 text-center">
                <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=800&q=80&auto=format&fit=crop" class="img-fluid rounded shadow-sm" alt="Our mission" />
            </div>
        </div>
    </section>
</div>
